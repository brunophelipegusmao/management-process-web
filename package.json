{
  "name": "management-process",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm --parallel --filter @mgmt/web --filter @mgmt/api run dev",
    "dev:web": "pnpm --filter @mgmt/web run dev",
    "dev:api": "pnpm --filter @mgmt/api run start:dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm --filter @mgmt/api run test",
    "db:generate": "pnpm --filter @mgmt/api run db:generate",
    "db:migrate": "pnpm --filter @mgmt/api run db:migrate",
    "db:studio": "pnpm --filter @mgmt/api run db:studio"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@scarf/scarf",
      "esbuild",
      "msw",
      "sharp",
      "unrs-resolver"
    ]
  }
}
