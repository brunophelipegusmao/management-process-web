# Database
DATABASE_URL=postgres://user:pass@localhost:5432/management_process
DATABASE_POOL_MAX=10

# Server
PORT=3001

# Auth (BetterAuth)
BETTER_AUTH_SECRET=change-me-with-a-long-random-string
BETTER_AUTH_URL=http://localhost:3001
BETTER_AUTH_BASE_PATH=/auth

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# Email
EMAIL_PROVIDER=console          # smtp | console
EMAIL_FROM=nao-responda@gestaoprocessual.local

# SMTP (only required when EMAIL_PROVIDER=smtp)
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=you@example.com
SMTP_PASS=your_password
